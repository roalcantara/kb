{
  "private": true,
  "name": "@kb/wkp",
  "version": "0.1.0",
  "description": "KodexB - Personal Knowledge Base",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist tmp",
    "cleanup": "bun run clean && rm -rf node_modules bun.lock*",
    "reinstall": "bun run cleanup && bun install",
    "build": "bun build index.ts --compile --outfile dist/kb",
    "dev": "bun run index.ts",
    "dev:watch": "bun run dev -- --watch --hot",
    "test": "bun test --pass-with-no-tests",
    "test:watch": "bun run test -- --watch",
    "typecheck": "tsc --noEmit",
    "lint": "e=0; bun run typecheck || e=1; exit $e"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "bun-types": "^1.3.11",
    "typescript": "^5"
  }
}