## Factories (`src/__tests__/factories/`)

### Setup

```typescript
// src/__tests__/factories/index.ts
// Central export - import all factories from here
export { taskFactory }    from './task.domain.factory'
export { projectFactory } from './project.domain.factory'
export { userFactory }    from './user.domain.factory'
```

### Task Factory

```typescript
// src/__tests__/factories/task.domain.factory.ts

import { Factory } from 'fishery'
import { Task, TaskStatus, TaskPriority } from '@core/tasks/task.types'
import { randomUUID } from 'crypto'

export const taskFactory = Factory.define<Task>(({ sequence }) => ({
  id:          `task-${sequence}`,
  projectId:   'proj-1',
  title:       `Task ${sequence}`,
  description: null,
  status:      'todo' as TaskStatus,
  priority:    'medium' as TaskPriority,
  dueAt:       null,
  tags:        [],
  createdAt:   new Date('2024-01-01'),
  updatedAt:   new Date('2024-01-01'),
}))

// ✅ Usage:
// taskFactory.build()                              - default task
// taskFactory.build({ status: 'done' })            - override one field
// taskFactory.buildList(3)                         - list of 3 tasks
// taskFactory.build({ title: 'Pay bills', tags: ['finance'] })
```

### Project Factory

```typescript
