## PATTERNS

### Describe the file and function (BetterSpecs - Describe Your Methods)

```typescript
// ✅ Top-level describe = file path relative to src/
// Inner describe = exact function name
describe('task.domain', () => {
  describe('validateTitle', () => { ... })
  describe('canTransitionTo', () => { ... })
  describe('isOverdue', () => { ... })
  describe('applyTaskUpdate', () => { ... })
})

// ❌ Never: vague top-level descriptions
describe('task utilities', () => { ... })          // too vague
describe('the task module and its helpers', () => { ... }) // never
```

### Context blocks (BetterSpecs - Use Contexts, BDD - Given/When/Then)

```typescript
// ✅ context = When / With / Without
// Maps to BDD: Given (factory setup) → When (context) → Then (it)
describe('validateTitle', () => {
  context('when title is valid', () => {
    it('returns ok with trimmed value', () => { ... })
  })

  context('when title is empty', () => {
    it('returns a VALIDATION error', () => { ... })
    it('identifies the field as "title"', () => { ... })
  })

  context('when title is only whitespace', () => {
    it('returns a VALIDATION error', () => { ... })
  })

  context('when title exceeds 200 characters', () => {
    it('returns a VALIDATION error', () => { ... })
  })
})

// ❌ Never: context descriptions without when/with/without
context('invalid title', () => { ... })            // missing "when"
context('the user is not found', () => { ... })    // missing "when"
```

### Short `it` descriptions (BetterSpecs - Keep Your Description Short)

```typescript
// ✅ Short - the context carries the meaning
context('when title is empty', () => {
  it('returns a VALIDATION error', () => { ... })  // clear, short
})

// ❌ Never: long it descriptions that duplicate the context
it('returns a VALIDATION error when the title is empty and the user did not provide a value', () => { ... })
```

### One-liner declarative assertions (Shoulda Matchers spirit)

```typescript
// ✅ For simple boolean or ok/fail checks - terse one-liner
context('when title is valid', () => {
  it('returns ok', () => expect(validateTitle('Write tests').ok).toBe(true))
})

context('when title is empty', () => {
  it('returns fail', () => expect(validateTitle('').ok).toBe(false))
})

// ✅ For richer assertions - multi-line is fine when you need to inspect the error
context('when title is empty', () => {
  it('returns a VALIDATION error for field "title"', () => {
    const result = validateTitle('')
    expect(result.ok).toBe(false)
    if (!result.ok) {
      expect(result.error.kind).toBe('VALIDATION')
      expect(result.error.field).toBe('title')
    }
  })
})

// ❌ Never: multi-line when one line is enough
context('when valid', () => {
  it('returns ok', () => {
    const result = validateTitle('Write tests')  // unnecessary verbosity
    expect(result.ok).toBe(true)
  })
})
```

### Table-driven tests with `it.each` (DRY up cases)

```typescript
// ✅ Use it.each for multiple inputs to the same rule

describe('validateTitle', () => {
  describe('valid inputs', () => {
    it.each([
      ['normal title',          'Write tests'],
      ['title with spaces',     '  Write tests  '],
      ['single character',      'A'],
      ['exactly 200 chars',     'A'.repeat(200)],
    ])('returns ok - %s', (_, title) => {
      expect(validateTitle(title).ok).toBe(true)
    })
  })

  describe('invalid inputs', () => {
    it.each([
      ['empty string',          ''],
      ['only whitespace',       '   '],
      ['201 characters',        'A'.repeat(201)],
    ])('returns VALIDATION error - %s', (_, title) => {
      expect(validateTitle(title).ok).toBe(false)
    })
  })
})

describe('canTransitionTo', () => {
  it.each([
    // from            to              allowed
    ['todo',        'in_progress',  true],
    ['todo',        'cancelled',    true],
    ['todo',        'done',         false],
    ['in_progress', 'done',         true],
    ['in_progress', 'cancelled',    true],
    ['in_progress', 'todo',         true],
    ['done',        'todo',         false],
    ['done',        'in_progress',  false],
    ['done',        'cancelled',    false],
    ['cancelled',   'todo',         false],
    ['cancelled',   'in_progress',  false],
    ['cancelled',   'done',         false],
  ] as const)('%s → %s returns %s', (from, to, expected) => {
    expect(canTransitionTo(from, to)).toBe(expected)
  })
})

// ❌ Never: one it block per case when a table covers them all
it('returns true for todo → in_progress', () => ...)
it('returns true for todo → cancelled', () => ...)
it('returns false for todo → done', () => ...)
// ... 9 more identical blocks
```

### Table-driven tests with `describe.each` (DRY up cases)

```typescript
// ✅ Use describe.each for multiple inputs to the same rule
describe.each([
  ['todo',        'in_progress',  true],
  ['todo',        'cancelled',    true],
  ['todo',        'done',         false],
])('canTransitionTo %s → %s returns %s', (from, to, expected) => {
  expect(canTransitionTo(from, to)).toBe(expected)
})
```

### Single expectation rule (BetterSpecs)

```typescript
// ✅ One assertion per it - failures point to the exact broken behaviour
context('when task is overdue', () => {
  it('returns true', () =>
    expect(isOverdue(taskFactory.build({ dueAt: yesterday, status: 'todo' }), now)).toBe(true)
  )
})

// ✅ Exception: integration/shell tests may assert multiple things
//    to avoid expensive setup duplication (BetterSpecs acknowledges this)
it('creates and persists a task', async () => {
  const result = await taskAddCommand(['Pay bills', '--project=proj-1'])
  const stored = await findTaskById(db, result.taskId)
  expect(stored).not.toBeNull()
  expect(stored?.title).toBe('Pay bills')
  expect(stored?.status).toBe('todo')
})

// ❌ Never: multiple assertions in a core test
it('validates and trims the title', () => {
  const result = validateTitle('  hello  ')
  expect(result.ok).toBe(true)          // two assertions
  if (result.ok) expect(result.value).toBe('hello')  // in one it - split these
})
```

### Test all cases (BetterSpecs - Test All Possible Cases)

```typescript
// ✅ Cover valid, invalid, AND edge cases
describe('validateDueAt', () => {
  context('with a valid ISO date string', () => {
    it('returns ok with a Date object', () => ...)
  })

  context('with null', () => {
    it('returns ok with null', () => ...)  // edge: optional field
  })

  context('with an invalid date string', () => {
    it('returns a VALIDATION error', () => ...)
  })

  context('with an empty string', () => {
    it('returns a VALIDATION error', () => ...)  // edge: empty ≠ null
  })
})

// ❌ Never: test only the happy path
describe('validateDueAt', () => {
  it('validates a date', () => ...)  // only one case - insufficient
})
```

### Immutability tests - always explicit (FCIS-specific)

```typescript
// ✅ Every function that returns a new value MUST have an immutability test
describe('applyTaskUpdate', () => {
  context('when called with a patch', () => {
    it('returns a new task object', () => {
      const task    = taskFactory.build({ title: 'Original' })
      const updated = applyTaskUpdate(task, { title: 'Updated' }, new Date())
      expect(updated).not.toBe(task)              // different reference
    })

    it('does not mutate the original task', () => {
      const task = taskFactory.build({ title: 'Original' })
      applyTaskUpdate(task, { title: 'Updated' }, new Date())
      expect(task.title).toBe('Original')         // original untouched
    })

    it('applies the patch to the returned task', () => {
      const task    = taskFactory.build()
      const updated = applyTaskUpdate(task, { title: 'Updated' }, new Date())
      expect(updated.title).toBe('Updated')
    })

    it('sets updatedAt to the provided timestamp', () => {
      const now     = new Date('2024-06-01')
      const task    = taskFactory.build()
      const updated = applyTaskUpdate(task, {}, now)
      expect(updated.updatedAt).toEqual(now)
    })
  })
})
```

### Result<T,E> - always test both branches

```typescript
// ✅ Test both ok and fail branches - never assume one
describe('createTask', () => {
  context('when input is valid', () => {
    it('returns ok', () => {
      const result = createTask(projectFactory.build(), { title: 'Pay bills' }, new Date())
      expect(result.ok).toBe(true)
    })

    it('includes the new task in the result', () => {
      const result = createTask(projectFactory.build(), { title: 'Pay bills' }, new Date())
      if (result.ok) expect(result.value.task.title).toBe('Pay bills')
    })
  })

  context('when title is empty', () => {
    it('returns fail', () => {
      const result = createTask(projectFactory.build(), { title: '' }, new Date())
      expect(result.ok).toBe(false)
    })

    it('returns a VALIDATION error', () => {
      const result = createTask(projectFactory.build(), { title: '' }, new Date())
      if (!result.ok) expect(result.error.kind).toBe('VALIDATION')
    })
  })

  context('when priority is invalid', () => {
    it('returns fail', () => {
      const result = createTask(projectFactory.build(), { title: 'Ok', priority: 'urgent' }, new Date())
      expect(result.ok).toBe(false)
    })
  })
})
```

