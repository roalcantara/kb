## Complete Example - `task.flow.spec.ts`

```typescript
// src/core/task/task.flow.spec.ts

import { describe, expect, it } from 'bun:test'

const context = describe

import { taskFactory, projectFactory }   from '@/__tests__/factories'
import { createTask, transitionTask }    from './task.flow'

const NOW = new Date('2024-06-01')

describe('task.flow', () => {

  // ── createTask ──────────────────────────────────────────────────────────────

  describe('createTask', () => {
    context('when input is valid', () => {
      const project = projectFactory.build()
      const input   = { title: 'Pay bills', priority: 'high' }

      it('returns ok', () =>
        expect(createTask(project, input, NOW).ok).toBe(true)
      )

      it('assigns the project id', () => {
        const result = createTask(project, input, NOW)
        if (result.ok) expect(result.value.task.projectId).toBe(project.id)
      })

      it('sets status to todo', () => {
        const result = createTask(project, input, NOW)
        if (result.ok) expect(result.value.task.status).toBe('todo')
      })

      it('sets createdAt to the provided timestamp', () => {
        const result = createTask(project, input, NOW)
        if (result.ok) expect(result.value.task.createdAt).toEqual(NOW)
      })

      it('generates a unique id', () => {
        const r1 = createTask(project, input, NOW)
        const r2 = createTask(project, input, NOW)
        if (r1.ok && r2.ok) expect(r1.value.task.id).not.toBe(r2.value.task.id)
      })
    })

    context('when title is empty', () => {
      it('returns fail', () =>
        expect(createTask(projectFactory.build(), { title: '' }, NOW).ok).toBe(false)
      )

      it('returns a VALIDATION error for field "title"', () => {
        const result = createTask(projectFactory.build(), { title: '' }, NOW)
        if (!result.ok) {
          expect(result.error.kind).toBe('VALIDATION')
          if (result.error.kind === 'VALIDATION') expect(result.error.field).toBe('title')
        }
      })
    })

    context('when priority is not a valid enum value', () => {
      it('returns fail', () =>
        expect(createTask(projectFactory.build(), { title: 'Ok', priority: 'urgent' }, NOW).ok).toBe(false)
      )
    })

    context('without a priority', () => {
      it('defaults to medium', () => {
        const result = createTask(projectFactory.build(), { title: 'Ok' }, NOW)
        if (result.ok) expect(result.value.task.priority).toBe('medium')
      })
    })
  })

  // ── transitionTask ──────────────────────────────────────────────────────────

  describe('transitionTask', () => {
    context('when transition is allowed', () => {
      it('returns ok', () => {
        const task   = taskFactory.build({ status: 'todo' })
        const result = transitionTask(task, { toStatus: 'in_progress' }, NOW)
        expect(result.ok).toBe(true)
      })

      it('returns the updated task with the new status', () => {
        const task   = taskFactory.build({ status: 'todo' })
        const result = transitionTask(task, { toStatus: 'in_progress' }, NOW)
        if (result.ok) expect(result.value.updatedTask.status).toBe('in_progress')
      })

      it('does not mutate the original task', () => {
        const task = taskFactory.build({ status: 'todo' })
        transitionTask(task, { toStatus: 'in_progress' }, NOW)
        expect(task.status).toBe('todo')
      })
    })

    context('when transition is not allowed', () => {
      it.each([
        ['done',      'todo'],
        ['done',      'in_progress'],
        ['cancelled', 'todo'],
        ['cancelled', 'done'],
      ] as const)('from %s to %s returns fail', (from, to) => {
        const task   = taskFactory.build({ status: from })
        const result = transitionTask(task, { toStatus: to }, NOW)
        expect(result.ok).toBe(false)
      })

      it('returns a BUSINESS_RULE error', () => {
        const task   = taskFactory.build({ status: 'done' })
        const result = transitionTask(task, { toStatus: 'todo' }, NOW)
        if (!result.ok) expect(result.error.kind).toBe('BUSINESS_RULE')
      })
    })
  })
})
```

