## Shell / Integration Tests

```typescript
// src/shell/cli/commands/task/add.spec.ts
// Integration tests - allowed to be async, use DB, use factory.create()

import { afterEach, beforeEach, describe, expect, it } from 'bun:test'

const context = describe
import { taskFactory, projectFactory } from '@/__tests__/factories'
import { taskAddCommand }  from './add.command'
import { findTaskById }    from '../../../db/queries/task.queries.db'
import { setupTestDb, teardownTestDb } from '@/__tests__/helpers/db'

describe('add.command', () => {
  describe('taskAddCommand', () => {
    // ✅ beforeEach is allowed in integration tests - needs fresh DB state
    beforeEach(async () => { await setupTestDb() })
    afterEach(async ()  => { await teardownTestDb() })

    context('when input is valid', () => {
      it('exits without error', async () => {
        const project = await projectFactory.create()
        await expect(
          taskAddCommand(['Pay bills', `--project=${project.id}`])
        ).resolves.not.toThrow()
      })

      it('persists the task to the database', async () => {
        const project = await projectFactory.create()
        const { taskId } = await taskAddCommand(['Pay bills', `--project=${project.id}`])
        const stored = await findTaskById(db, taskId)
        expect(stored).not.toBeNull()
        expect(stored?.title).toBe('Pay bills')
      })
    })

    context('when project does not exist', () => {
      it('exits with code 1', async () => {
        await expect(
          taskAddCommand(['Pay bills', '--project=nonexistent'])
        ).rejects.toThrow()
      })
    })
  })
})
```

