### User Factory

```typescript
// src/__tests__/factories/user.domain.factory.ts

import { Factory } from 'fishery'
import { User, UserRole } from '@core/users/user.types'

export const userFactory = Factory.define<User>(({ sequence }) => ({
  id:       `user-${sequence}`,
  username: `user${sequence}`,
  role:     'viewer' as UserRole,
}))

// Trait-like variants via build() overrides:
// userFactory.build({ role: 'admin' })   - admin user
// userFactory.build({ role: 'viewer' })  - viewer (default)
```

### Factory Rules

```typescript
// ✅ Use build() in core tests - synchronous, no DB
const task = taskFactory.build({ status: 'done' })

// ✅ Use buildList() for collection tests
const tasks = taskFactory.buildList(3, { status: 'todo' })

// ✅ Use create() only in shell/integration tests - async, hits DB
const task = await taskFactory.create({ title: 'Persisted task' })

// ✅ Compose factories - project owns tasks
const project = projectFactory.build()
const task    = taskFactory.build({ projectId: project.id })

// ❌ Never: hand-written object literals in tests when a factory exists
// ❌ Never: create() in core tests - core tests are synchronous
// ❌ Never: one mega-factory with 20 parameters - keep factories minimal
```

