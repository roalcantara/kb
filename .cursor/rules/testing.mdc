## Complete Example - `task.domain.spec.ts`

```typescript
// src/core/task/task.domain.spec.ts

import { describe, expect, it } from 'bun:test'

const context = describe

import { taskFactory, projectFactory }   from '@/__tests__/factories'
import {
  validateTitle,
  validatePriority,
  canTransitionTo,
  isOverdue,
  applyTaskUpdate,
} from './task.domain'

const NOW      = new Date('2024-06-01')
const PAST     = new Date('2024-01-01')
const FUTURE   = new Date('2025-01-01')

// ── validateTitle ─────────────────────────────────────────────────────────────

describe('task.domain', () => {
  describe('validateTitle', () => {
    describe('valid inputs - returns ok', () => {
      it.each([
        ['a normal title',    'Write tests'],
        ['padded whitespace', '  Write tests  '],
        ['single character',  'A'],
        ['exactly 200 chars', 'A'.repeat(200)],
      ])('%s', (_, title) => expect(validateTitle(title).ok).toBe(true))
    })

    describe('trims the value on success', () => {
      it('returns trimmed value', () => {
        const result = validateTitle('  Write tests  ')
        if (result.ok) expect(result.value).toBe('Write tests')
      })
    })

    describe('invalid inputs - returns VALIDATION error', () => {
      it.each([
        ['empty string',   ''],
        ['only spaces',    '   '],
        ['201 characters', 'A'.repeat(201)],
      ])('%s', (_, title) => {
        const result = validateTitle(title)
        expect(result.ok).toBe(false)
        if (!result.ok) expect(result.error.kind).toBe('VALIDATION')
      })
    })
  })

  // ── validatePriority ──────────────────────────────────────────────────────

  describe('validatePriority', () => {
    describe('valid values', () => {
      it.each([['low'], ['medium'], ['high']])('%s returns ok', (priority) => {
        expect(validatePriority(priority).ok).toBe(true)
      })
    })

    describe('invalid values', () => {
      it.each([['urgent'], ['critical'], [''], ['LOW']])('%s returns fail', (priority) => {
        expect(validatePriority(priority).ok).toBe(false)
      })
    })
  })

  // ── canTransitionTo ───────────────────────────────────────────────────────

  describe('canTransitionTo', () => {
    it.each([
      // from            to              expected  label
      ['todo',        'in_progress',  true,  'starts work'],
      ['todo',        'cancelled',    true,  'cancels before starting'],
      ['todo',        'done',         false, 'cannot skip in_progress'],
      ['in_progress', 'done',         true,  'completes work'],
      ['in_progress', 'cancelled',    true,  'cancels in flight'],
      ['in_progress', 'todo',         true,  'moves back to backlog'],
      ['done',        'todo',         false, 'terminal: cannot reopen'],
      ['done',        'in_progress',  false, 'terminal: cannot restart'],
      ['done',        'cancelled',    false, 'terminal: cannot cancel'],
      ['cancelled',   'todo',         false, 'terminal: cannot reopen'],
      ['cancelled',   'in_progress',  false, 'terminal: cannot restart'],
      ['cancelled',   'done',         false, 'terminal: cannot complete'],
    ] as const)('%s → %s (%s)', (from, to, expected) => {
      expect(canTransitionTo(from, to)).toBe(expected)
    })
  })

  // ── isOverdue ─────────────────────────────────────────────────────────────

  describe('isOverdue', () => {
    context('when dueAt is in the past', () => {
      context('with status todo', () => {
        it('returns true', () =>
          expect(isOverdue(taskFactory.build({ dueAt: PAST, status: 'todo' }), NOW)).toBe(true)
        )
      })

      context('with status in_progress', () => {
        it('returns true', () =>
          expect(isOverdue(taskFactory.build({ dueAt: PAST, status: 'in_progress' }), NOW)).toBe(true)
        )
      })

      context('with status done', () => {
        it('returns false - completed tasks are never overdue', () =>
          expect(isOverdue(taskFactory.build({ dueAt: PAST, status: 'done' }), NOW)).toBe(false)
        )
      })

      context('with status cancelled', () => {
        it('returns false - cancelled tasks are never overdue', () =>
          expect(isOverdue(taskFactory.build({ dueAt: PAST, status: 'cancelled' }), NOW)).toBe(false)
        )
      })
    })

    context('when dueAt is in the future', () => {
      it('returns false', () =>
        expect(isOverdue(taskFactory.build({ dueAt: FUTURE, status: 'todo' }), NOW)).toBe(false)
      )
    })

    context('without a dueAt', () => {
      it('returns false', () =>
        expect(isOverdue(taskFactory.build({ dueAt: null }), NOW)).toBe(false)
      )
    })
  })

  // ── applyTaskUpdate ───────────────────────────────────────────────────────

  describe('applyTaskUpdate', () => {
    context('when called with a patch', () => {
      it('returns a new object reference', () => {
        const task = taskFactory.build()
        expect(applyTaskUpdate(task, { title: 'New' }, NOW)).not.toBe(task)
      })

      it('does not mutate the original', () => {
        const task = taskFactory.build({ title: 'Original' })
        applyTaskUpdate(task, { title: 'Updated' }, NOW)
        expect(task.title).toBe('Original')
      })

      it('applies the patch fields', () => {
        const task    = taskFactory.build()
        const updated = applyTaskUpdate(task, { title: 'Updated', priority: 'high' }, NOW)
        expect(updated.title).toBe('Updated')
        expect(updated.priority).toBe('high')
      })

      it('sets updatedAt to the provided timestamp', () => {
        const task    = taskFactory.build()
        const updated = applyTaskUpdate(task, {}, NOW)
        expect(updated.updatedAt).toEqual(NOW)
      })

      it('preserves unpatch fields unchanged', () => {
        const task    = taskFactory.build({ description: 'Keep this' })
        const updated = applyTaskUpdate(task, { title: 'New title' }, NOW)
        expect(updated.description).toBe('Keep this')
      })
    })
  })
})
```

