{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["esnext"],
    "target": "esnext",
    "module": "esnext",
    "moduleDetection": "force",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowJs": true,
    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noPropertyAccessFromIndexSignature": false,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "noErrorTruncation": false, // true keeps full error messages - for better debugging
    "exactOptionalPropertyTypes": true,
    "types": ["bun", "bun-types"],
    "paths": {
      "@kb/core": ["./apps/kb/src/core/index.ts"],
      "@kb/kli/headless": ["./packages/kli/src/headless.app.ts"],
      "@kb/kli/testing": ["./packages/kli/src/__tests__/testing.ts"],
      "@kb/kli": ["./packages/kli/src/main.app.ts"],
      "@kb/shell": ["./apps/kb/src/index.ts"],
      "@kli/tests": ["./packages/kli/src/__tests__/index.ts"],
      "@kli/core/cli": ["./packages/kli/src/core/cli/index.ts"],
      "@kli/shell/cli": ["./packages/kli/src/shell/cli/index.ts"],
      "@kli/shell/tui": ["./packages/kli/src/shell/tui/index.ts"],
      "@core": ["./apps/kb/src/core/index.ts"],
      "@shell": ["./apps/kb/src/index.ts"],
      "@tools": ["./tools/index.ts"],
      "@tests": ["./__tests__/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist", "temp"]
}
