{
  "$schema": "https://unpkg.com/knip@5/schema-jsonc.json",
  "workspaces": {
    ".": {
      "entry": ["package.json", "src/shell/index.headless.ts"],
      "project": ["**/*.ts", "**/*.tsx"]
    },
    "packages/kli": {
      "entry": ["package.json"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreBinaries": ["mise", "dot"],
  "ignoreFiles": ["**/tools/**", ".cursor/**", "**/*.typetest.ts"]
}
